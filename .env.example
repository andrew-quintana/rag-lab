# Environment Variables Template

# Database (Supabase Postgres)
SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your_supabase_anon_key_here
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Azure Document Intelligence (OCR & Text Extraction)
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=your_document_intelligence_api_key_here

# Azure AI Foundry
AZURE_AI_FOUNDRY_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_AI_FOUNDRY_API_KEY=your_api_key_here
AZURE_AI_FOUNDRY_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_AI_FOUNDRY_GENERATION_MODEL=gpt-4
AZURE_AI_FOUNDRY_GENERATION_MODEL=gpt-4o-mini
AZURE_AI_FOUNDRY_REASONING_MODEL=gpt-4o

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your_search_api_key_here
AZURE_SEARCH_INDEX_NAME=rag-index

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER_NAME=documents

# Azure Storage Queues
AZURE_STORAGE_ENDPOINT=https://your-queue-service.queue.core.windows.net/
AZURE_STORAGE_API_KEY=your_storage_queues_api_key_here
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_account;AccountKey=your_key;EndpointSuffix=core.windows.net
AZURE_STORAGE_NAME=your_storage_queue_name_here

# Azure App Insights
AZURE_APPINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend
VITE_API_BASE_URL=http://localhost:8000



